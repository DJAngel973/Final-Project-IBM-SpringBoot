# Copy this file to .env and fill in the values.
# .env is ignored by git — never commit real credentials.

# PostgreSQL connection
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/Example_app_questionnaire
SPRING_DATASOURCE_USERNAME=Example_your_db_user
SPRING_DATASOURCE_PASSWORD=Example_your_db_password

# PostgreSQL container credentials (used by docker-compose for the db service)
POSTGRES_DB=Example_app_questionnaire
POSTGRES_USER=Example_your_db_user
POSTGRES_PASSWORD=Example_your_db_password
